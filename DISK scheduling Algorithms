//FCFS
#include <iostream>
#include <vector>
#include <cmath>
using namespace std;

int main() {
    int n, head;

    cout << "Enter number of requests: ";
    cin >> n;

    vector<int> requests(n);

    cout << "Enter the request sequence:\n";
    for(int i = 0; i < n; i++) {
        cin >> requests[i];
    }

    cout << "Enter initial head position: ";
    cin >> head;

    int totalSeekTime = 0;

    cout << "\nSeek Sequence: ";

    for(int i = 0; i < n; i++) {
        cout << requests[i] << " ";
        totalSeekTime += abs(head - requests[i]);
        head = requests[i];
    }

    cout << "\n\nTotal Seek Time = " << totalSeekTime << endl;

    return 0;
}

